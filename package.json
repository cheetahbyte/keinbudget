{
  "name": "keinbudget",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@types/bun": "latest",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "scripts": {
    "dev": "bun run --elide-lines=0 --filter '*' dev",
    "dev:web": "bun run --elide-lines=0 --filter @keinbudget/web dev",
    "dev:api": "bun run --elide-lines=0 --filter @keinbudget/api dev",
    "db:push": "bun run --filter @keinbudget/db push",
    "db:generate": "bun run --filter @keinbudget/db generate",
    "db:migrate": "bun run --filter @keinbudget/db migrate",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "packageManager": "bun@1.3.13"
}
