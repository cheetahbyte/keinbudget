{
  "name": "keinbudget",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "type": "module",
  "private": true,
  "devDependencies": {
    "@biomejs/biome": "2.2.0",
    "@types/bun": "latest",
    "typescript": "^6"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "scripts": {
    "dev": "bun --filter '*' dev",
    "dev:web": "bun --filter web dev",
    "dev:api": "bun --filter api dev",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "packageManager": "bun@1.3.13"
}
