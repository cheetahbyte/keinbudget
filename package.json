{
  "name": "keinbudget",
  "type": "module",
  "private": true,
  "devDependencies": {
    "@types/node": "^22.15.21",
    "@biomejs/biome": "2.2.0",
    "@tailwindcss/postcss": "^4.2.4",
    "tailwindcss": "^4.2.4",
    "tsx": "^4.20.6",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6"
  },
  "peerDependencies": {
    "typescript": "^6"
  },
  "scripts": {
    "dev": "pnpm -r --parallel --if-present dev",
    "dev:web": "pnpm --filter @keinbudget/web dev",
    "dev:api": "pnpm --filter @keinbudget/api dev",
    "db:push": "pnpm --filter @keinbudget/db push",
    "db:generate": "pnpm --filter @keinbudget/db generate",
    "db:migrate": "pnpm --filter @keinbudget/db migrate",
    "lint": "biome check .",
    "format": "biome format --write ."
  },
  "engines": {
    "node": ">=22.15.0"
  },
  "packageManager": "pnpm@10.11.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  }
}
